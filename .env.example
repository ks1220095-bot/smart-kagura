# Server Config
PORT=5000

# SMTP config for Nodemailer (For real email sending)
# To use Gmail, set host to smtp.gmail.com, port to 587, and use an App Password for pass.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=your-email@example.com

# Shrine Admin Info (Where notification mails go)
ADMIN_EMAIL=admin-shrine@example.com
